---
import LangPicker from './LangPicker.astro';
import { translate, type Lang } from '../scripts/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const links = [
  { href: '#welcome',  key: 'nav_welcome'  },
  { href: '#location', key: 'nav_location' },
  { href: '#dress',    key: 'nav_dress'    },
  { href: '#speeches', key: 'nav_speeches' },
  { href: '#gifts',    key: 'nav_gifts'    },
  { href: '#contact',  key: 'nav_contact'  },
];
---

<nav class="nav" data-nav aria-label="Site navigation">
  <a href="#" class="nav__brand">{translate('site_title', lang)}</a>

  <button
    class="nav__toggle"
    type="button"
    data-nav-toggle
    aria-expanded="false"
    aria-label="Open navigation menu"
    aria-controls="nav-panel"
  >
    <span class="nav__toggle-bar"></span>
    <span class="nav__toggle-bar"></span>
    <span class="nav__toggle-bar"></span>
  </button>

  <div class="nav__panel" id="nav-panel" data-nav-panel>
    <ul class="nav__links" role="list">
      {links.map(({ href, key }) => (
        <li>
          <a href={href} class="nav__link" data-nav-link>{translate(key, lang)}</a>
        </li>
      ))}
      <li hidden data-rsvp-navlink>
        <span class="nav__rsvp-sep" aria-hidden="true">·</span>
        <a href="#rsvp" class="nav__link nav__link--rsvp" data-nav-link>{translate('nav_rsvp', lang)}</a>
      </li>
    </ul>
    <div class="nav__lang">
      <LangPicker lang={lang} />
    </div>
  </div>
</nav>

<style>
  /* ── Base ─────────────────────────────────────────────────────── */
  .nav {
    /* Anchored above the hero; sticks to the top on scroll. Always solid. */
    position: sticky;
    inset-block-start: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-3);
    padding-inline: clamp(1.5rem, 5vw, 3.5rem);
    color: var(--color-ink);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Brand ────────────────────────────────────────────────────── */
  .nav__brand {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
    margin-inline-end: auto;
  }

  .nav__brand:hover {
    opacity: 0.8;
  }

  /* ── Panel (desktop: inline; mobile: overlay) ─────────────────── */
  .nav__panel {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* ── Links ────────────────────────────────────────────────────── */
  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 400;
    letter-spacing: 0.015em;
    color: inherit;
    text-decoration: none;
    padding-block-end: 2px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__link { transition: none; }
  }

  .nav__link:hover,
  .nav__link:focus-visible {
    border-bottom-color: currentColor;
  }

  .nav__rsvp-sep {
    color: inherit;
    opacity: 0.45;
    margin-inline-end: var(--space-2);
    font-size: var(--step--1);
  }

  /* ── Hamburger ────────────────────────────────────────────────── */
  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: inherit;
    flex-shrink: 0;
  }

  .nav__toggle-bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__toggle-bar { transition: none; }
  }

  /* ── Lang picker wrapper ───────────────────────────────────────── */
  .nav__lang {
    flex-shrink: 0;
  }

  /* ── Mobile ───────────────────────────────────────────────────── */
  @media (max-width: 820px) {
    .nav__toggle {
      display: flex;
      order: 1;
      margin-inline-start: auto;
    }

    .nav__panel {
      position: fixed;
      inset: 0;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: var(--space-6);
      background: var(--color-inverse-bg);
      color: var(--color-inverse-text);
      visibility: hidden;
      opacity: 0;
      transition: opacity 0.2s ease, visibility 0.2s ease;
      overflow-y: auto;
    }

    @media (prefers-reduced-motion: reduce) {
      .nav__panel { transition: none; }
    }

    .nav__panel[data-open] {
      visibility: visible;
      opacity: 1;
    }

    .nav__links {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }

    .nav__link {
      font-size: var(--step-1);
      font-weight: 500;
      letter-spacing: 0.01em;
    }

    .nav__rsvp-sep {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-nav-panel]');

  // ── RSVP link: reveal only when ?id param is present ────────────
  if (new URLSearchParams(location.search).get('id')) {
    document.querySelectorAll<HTMLElement>('[data-rsvp-navlink]').forEach((el) => {
      el.hidden = false;
    });
  }

  // ── Hamburger toggle ─────────────────────────────────────────────
  function openMenu() {
    panel?.setAttribute('data-open', '');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close navigation menu');
  }

  function closeMenu() {
    panel?.removeAttribute('data-open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open navigation menu');
  }

  toggle?.addEventListener('click', () => {
    if (panel?.hasAttribute('data-open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Close menu when any nav link is clicked
  panel?.querySelectorAll<HTMLAnchorElement>('[data-nav-link]').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
