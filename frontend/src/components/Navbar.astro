---
import LangPicker from './LangPicker.astro';
import { InviteeView } from '../islands/InviteeView';
import { translate, type Lang } from '../scripts/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const links = [
  { href: '#welcome',  key: 'nav_welcome'  },
  { href: '#location', key: 'nav_location' },
  { href: '#dress',    key: 'nav_dress'    },
  { href: '#speeches', key: 'nav_speeches' },
  { href: '#language', key: 'nav_language' },
  { href: '#gifts',    key: 'nav_gifts'    },
  { href: '#contact',  key: 'nav_contact'  },
];
---

<nav class="nav" data-nav aria-label={translate('nav_aria_label', lang)}>
  <div class="nav__inner">
    <a href="#" class="nav__brand">{translate('site_title', lang)}</a>

    <button
      class="nav__toggle"
      type="button"
      data-nav-toggle
      aria-expanded="false"
      aria-label={translate('nav_toggle_open', lang)}
      aria-controls="nav-panel"
      data-label-open={translate('nav_toggle_open', lang)}
      data-label-close={translate('nav_toggle_close', lang)}
    >
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
    </button>

    <div class="nav__panel" id="nav-panel" data-nav-panel>
      <ul class="nav__links" role="list">
        {links.map(({ href, key }) => (
          <li>
            <a href={href} class="nav__link" data-nav-link>{translate(key, lang)}</a>
          </li>
        ))}
        <InviteeView client:only="solid-js">
          <li>
            <a href="#rsvp" class="nav__link nav__link--rsvp" data-nav-link>{translate('nav_rsvp', lang)}</a>
          </li>
        </InviteeView>
      </ul>
      <div class="nav__lang">
        <LangPicker lang={lang} />
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const panel = document.querySelector('[data-nav-panel]');
  // Translated labels are passed in via data-* so the client script stays
  // language-agnostic (no hardcoded copy here).
  const labelOpen = toggle?.getAttribute('data-label-open') ?? '';
  const labelClose = toggle?.getAttribute('data-label-close') ?? '';
  function setOpen(open: boolean) {
    panel?.toggleAttribute('data-open', open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? labelClose : labelOpen);
  }
  toggle?.addEventListener('click', () => setOpen(!panel?.hasAttribute('data-open')));
  panel?.querySelectorAll('[data-nav-link]').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>

<style>
  /* ── Base ─────────────────────────────────────────────────────── */
  .nav {
    /* Full-bleed bar: anchored above the hero, sticks to the top on scroll. */
    position: sticky;
    inset-block-start: 0;
    z-index: 100;
    padding-block: var(--space-3);
    color: var(--color-ink);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* Content capped to the page width; the bar itself stays full-bleed.
     The gutter is folded into the width (not padding) so it never stacks with
     the centering margin. This keeps the content edges aligned with the hero. */
  .nav__inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    width: min(100% - 2 * var(--gutter), var(--width-wide));
    margin-inline: auto;
  }

  /* ── Brand ────────────────────────────────────────────────────── */
  .nav__brand {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
    margin-inline-end: auto;
  }

  .nav__brand:hover {
    opacity: 0.8;
  }

  /* ── Panel (desktop: inline; mobile: overlay) ─────────────────── */
  .nav__panel {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* ── Links ────────────────────────────────────────────────────── */
  .nav__links {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Dot separators between header items */
  .nav__links li::before {
    content: "·";
    margin-inline: var(--space-3);
    opacity: 0.45;
    color: inherit;
  }

  .nav__links > li:first-child::before {
    content: none;
  }

  .nav__link {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 400;
    letter-spacing: 0.015em;
    color: inherit;
    text-decoration: none;
    padding-block-end: 2px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__link { transition: none; }
  }

  .nav__link:hover,
  .nav__link:focus-visible {
    border-bottom-color: currentColor;
  }

  /* ── Hamburger ────────────────────────────────────────────────── */
  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: inherit;
    flex-shrink: 0;
    /* Stay tappable above the open overlay so it can close the menu. */
    position: relative;
    z-index: 2;
  }

  /* Open state: light ✕ that reads on the navy overlay. */
  .nav__toggle[aria-expanded='true'] {
    color: var(--color-inverse-text);
  }
  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .nav__toggle-bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__toggle-bar { transition: none; }
  }

  /* ── Lang picker wrapper ───────────────────────────────────────── */
  .nav__lang {
    flex-shrink: 0;
  }

  /* ── Mobile ───────────────────────────────────────────────────── */
  @media (max-width: 820px) {
    .nav__toggle {
      display: flex;
      order: 1;
      margin-inline-start: auto;
    }

    .nav__panel {
      position: fixed;
      inset: 0;
      z-index: 1;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: var(--space-6);
      background: var(--color-inverse-bg);
      color: var(--color-inverse-text);
      visibility: hidden;
      opacity: 0;
      transition: opacity 0.2s ease, visibility 0.2s ease;
      overflow-y: auto;
    }

    @media (prefers-reduced-motion: reduce) {
      .nav__panel { transition: none; }
    }

    .nav__panel[data-open] {
      visibility: visible;
      opacity: 1;
    }

    .nav__links {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }

    .nav__link {
      font-size: var(--step-1);
      font-weight: 500;
      letter-spacing: 0.01em;
    }

    .nav__links li::before {
      display: none;
    }
  }
</style>


