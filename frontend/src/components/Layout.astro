---
import '../styles/global.scss';
import '@fontsource/cormorant/500.css';
import '@fontsource/cormorant/600.css';
import '@fontsource/cormorant/500-italic.css';
import '@fontsource/work-sans/400.css';
import '@fontsource/work-sans/500.css';
import cormorant600Url from '@fontsource/cormorant/files/cormorant-latin-600-normal.woff2?url';
import cormorant500Url from '@fontsource/cormorant/files/cormorant-latin-500-normal.woff2?url';
import cormorant500ItalicUrl from '@fontsource/cormorant/files/cormorant-latin-500-italic.woff2?url';
import workSans400Url from '@fontsource/work-sans/files/work-sans-latin-400-normal.woff2?url';
import workSans500Url from '@fontsource/work-sans/files/work-sans-latin-500-normal.woff2?url';
import LangPicker from './LangPicker.astro';
import Container from './Container.astro';
import type { Lang } from '../scripts/i18n';
interface Props { title: string; lang: Lang; }
const { title, lang } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href={cormorant600Url} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={cormorant500Url} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={cormorant500ItalicUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={workSans400Url} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={workSans500Url} as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <slot name="topbar"><div class="topbar"><LangPicker lang={lang} /></div></slot>
    <slot name="hero" />
    <Container>
      <slot />
    </Container>
    <script>
      import { scrollToFragment } from '../scripts/nav';

      if (globalThis.location.hash) {
        // Defer until after hydration so client-only islands have populated.
        requestAnimationFrame(() => {
          scrollToFragment(globalThis.location.hash);
        });
      }
    </script>
  </body>
</html>

<style>
  .topbar { position: absolute; top: 0; right: 0; z-index: 20; padding: var(--space-3) var(--space-4); }
</style>
