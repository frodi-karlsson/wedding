---
import '../styles/global.scss';
import '../styles/fonts.scss';

// Self-hosted fonts: every file in ../assets/fonts is declared in fonts.scss and
// preloaded below. Globbing the folder means adding a weight needs no edit here.
const fontPreloadUrls = Object.values(
  import.meta.glob('../assets/fonts/*.woff2', { eager: true, query: '?url', import: 'default' }),
) as string[];
import LangPicker from './LangPicker.astro';
import Container from './Container.astro';
import type { Lang } from '../scripts/i18n';
interface Props { title: string; lang: Lang; }
const { title, lang } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {fontPreloadUrls.map((href) => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
    ))}
  </head>
  <body>
    <slot name="topbar"><div class="topbar"><LangPicker lang={lang} /></div></slot>
    <slot name="hero" />
    <Container>
      <slot />
    </Container>
    <script>
      import { scrollToFragment } from '../scripts/nav';

      if (globalThis.location.hash) {
        // Defer until after hydration so client-only islands have populated.
        requestAnimationFrame(() => {
          scrollToFragment(globalThis.location.hash);
        });
      }
    </script>
  </body>
</html>

<style>
  .topbar { position: absolute; top: 0; right: 0; z-index: 20; padding: var(--space-3) var(--space-4); }
</style>
