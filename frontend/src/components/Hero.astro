---
import BlurredImage from './BlurredImage.astro';
import heroImg from '../assets/carla-frodi-hero.jpg';
import { translate, type Lang } from '../scripts/i18n';
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';

const heroImgPath = resolve('src/assets/carla-frodi-hero.jpg');
const heroImgBuffer = await readFile(heroImgPath);

interface Props { lang: Lang; }
const { lang } = Astro.props;
---
<header class="hero surface--inverse">
  <div class="hero__media">
    <BlurredImage
      src={heroImg}
      lqipBuffer={heroImgBuffer}
      alt="Carla and Fróði"
      widths={[600, 900, 1200]}
      sizes="(max-width: 760px) 100vw, 50vw"
      loading="eager"
      fetchpriority="high"
      class="hero__img"
    />
  </div>
  <div class="hero__panel">
    <p class="hero__eyebrow">{translate('hero_coming_soon', lang)}</p>
    <h1 class="hero__names">{translate('site_title', lang)}</h1>
    <span class="hero__rule"></span>
    <p class="hero__date">{translate('hero_date', lang)}</p>
  </div>
</header>

<style>
  .hero {
    display: grid;
    /* minmax(0,1fr), not 1fr — keeps both columns a true 50/50 instead of
       letting the large heading's min-content width inflate the panel. */
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    grid-template-rows: 1fr;
    min-height: min(74vh, 640px);
    max-height: 80vh;
    max-width: var(--width-wide);
    margin-inline: auto;
    overflow: hidden;
  }

  /* On extra-wide screens the hero is boxed with side gutters — add a top gap
     so it feels centered in its area rather than flush under the navbar. */
  @media (min-width: 1400px) {
    .hero { margin-block-start: var(--space-12); }
  }
  .hero__media { position: relative; overflow: hidden; display: flex; }
  /* .hero__img is BlurredImage's root, so it carries BlurredImage's scope id,
     not Hero's — target it through .hero__media (which does have Hero's id)
     and globalize the child so these rules actually match. */
  .hero__media > :global(.hero__img) { flex: 1; min-width: 0; }
  .hero__media :global(.blurred-image__img) {
    object-fit: cover;
    object-position: 50% 20%;
  }
  .hero__panel {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-6);
    padding: clamp(2rem, 5vw, 4.5rem);
  }
  .hero__names {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--step-4);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: #fff;
  }
  .hero__rule { width: 56px; height: 2px; background: var(--color-inverse-accent); }
  .hero__eyebrow {
    font-family: var(--font-sans);
    font-weight: var(--weight-medium);
    font-size: var(--step--1);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-inverse-muted);
  }
  .hero__date {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    color: var(--color-inverse-text);
  }

  @media (max-width: 760px) {
    .hero {
      display: block;
      position: relative;
      min-height: 0;
      height: min(72vh, 600px);
    }
    .hero__media { position: absolute; inset: 0; overflow: hidden; }
    .hero__panel {
      position: absolute;
      inset: auto 0 0 0;
      z-index: 2;
      justify-content: flex-end;
      gap: var(--space-3);
      padding: var(--space-16) clamp(1.5rem, 6vw, 2.5rem) var(--space-6);
      background: linear-gradient(
        to top,
        rgb(27 46 74 / 0.97) 0%,
        rgb(27 46 74 / 0.88) 35%,
        rgb(27 46 74 / 0.55) 65%,
        rgb(27 46 74 / 0) 100%
      );
    }
    /* Clear "coming soon" over the photo: white + subtle shadow */
    .hero__eyebrow {
      color: #fff;
      text-shadow: 0 1px 6px rgb(27 46 74 / 0.55);
    }
  }
</style>
