---
import { Image } from 'astro:assets';
import heroImg from '../assets/carla-frodi-hero.jpg';
import { translate, type Lang } from '../scripts/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---
<header class="hero surface--inverse">
  <div class="hero__media">
    <Image
      src={heroImg}
      alt="Carla and Fróði"
      widths={[600, 900, 1200]}
      sizes="(max-width: 760px) 100vw, 50vw"
      class="hero__img"
    />
  </div>
  <div class="hero__panel">
    <h1 class="hero__names">{translate('site_title', lang)}</h1>
    <span class="hero__rule"></span>
  </div>
</header>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: min(74vh, 640px);
  }
  .hero__media { position: relative; overflow: hidden; }
  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 22%;
    display: block;
  }
  .hero__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-6);
    padding: clamp(2rem, 5vw, 4.5rem);
  }
  .hero__names {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: var(--step-4);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: #fff;
  }
  .hero__rule { width: 56px; height: 2px; background: var(--color-inverse-accent); }

  @media (max-width: 760px) {
    .hero { grid-template-columns: 1fr; }
    .hero__media { order: -1; min-height: 56vh; }
  }
</style>
