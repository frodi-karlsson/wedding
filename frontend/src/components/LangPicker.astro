---
import type { Lang } from '../scripts/i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const locales: { code: Lang; label: string }[] = [
  { code: 'en', label: 'EN' },
  { code: 'is', label: 'ÍS' },
  { code: 'de', label: 'DE' },
  { code: 'sv', label: 'SV' },
];

const localeCodes: Lang[] = ['is', 'de', 'sv'];
const firstSegment = Astro.url.pathname.split('/')[1];
const strippedPath =
  firstSegment && localeCodes.includes(firstSegment as Lang)
    ? Astro.url.pathname.slice(firstSegment.length + 1) || '/'
    : Astro.url.pathname;
const search = Astro.url.search;
---
<nav class="lang-picker">
  {locales.map((l) => {
    const prefix = l.code === 'en' ? '' : `/${l.code}`;
    const base = strippedPath === '/' ? prefix || '/' : `${prefix}${strippedPath}`;
    const href = `${base}${search}`;
    return <a href={href} aria-current={l.code === lang ? 'true' : undefined}>{l.label}</a>;
  })}
</nav>
