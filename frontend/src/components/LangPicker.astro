---
import type { Lang } from '../scripts/i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const locales: { code: Lang; label: string; flag: string }[] = [
  { code: 'en', label: 'English', flag: '🇬🇧' },
  { code: 'is', label: 'Íslenska', flag: '🇮🇸' },
  { code: 'de', label: 'Deutsch', flag: '🇩🇪' },
  { code: 'sv', label: 'Svenska', flag: '🇸🇪' },
];

const localeCodes: Lang[] = ['is', 'de', 'sv'];
const firstSegment = Astro.url.pathname.split('/')[1];
const strippedPath =
  firstSegment && localeCodes.includes(firstSegment as Lang)
    ? Astro.url.pathname.slice(firstSegment.length + 1) || '/'
    : Astro.url.pathname;
const search = Astro.url.search;

const current = locales.find((l) => l.code === lang) ?? locales[0];

function hrefFor(code: Lang): string {
  const prefix = code === 'en' ? '' : `/${code}`;
  const base = strippedPath === '/' ? prefix || '/' : `${prefix}${strippedPath}`;
  return `${base}${search}`;
}
---
<div class="lang-dropdown" data-lang-dropdown>
  <button type="button" class="lang-dropdown__trigger" aria-haspopup="listbox" aria-expanded="false" data-lang-toggle>
    <span class="lang-dropdown__flag">{current.flag}</span>
    <span class="lang-dropdown__label">{current.label}</span>
    <svg class="lang-dropdown__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <ul class="lang-dropdown__menu" role="listbox" hidden data-lang-menu>
    {locales.map((l) => (
      <li role="option" aria-selected={l.code === lang ? 'true' : 'false'}>
        <a href={hrefFor(l.code)} class="lang-dropdown__item" aria-current={l.code === lang ? 'true' : undefined}>
          <span class="lang-dropdown__flag">{l.flag}</span>
          <span>{l.label}</span>
        </a>
      </li>
    ))}
  </ul>
</div>
<script>
  const dropdown = document.querySelector('[data-lang-dropdown]');
  if (dropdown) {
    const trigger = dropdown.querySelector('[data-lang-toggle]');
    const menu = dropdown.querySelector('[data-lang-menu]');
    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
      menu?.toggleAttribute('hidden', expanded);
    });
    document.addEventListener('click', () => {
      trigger?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('hidden', '');
    });
  }
</script>
