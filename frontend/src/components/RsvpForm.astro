---
import { translate, type Lang } from '../scripts/i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
---
<div id="rsvp-root" data-lang={lang}>
  <p class="error">{translate('no_id_error', lang)}</p>
</div>
<script type="module">
  const root = document.getElementById('rsvp-root');
  if (root) {
    const { mountRsvpForm } = await import('../scripts/rsvp-form');
    const lang = /** @type {import('../scripts/i18n').Lang} */ (root.dataset.lang);
    const id = new URLSearchParams(globalThis.location.search).get('id');
    const heading = document.querySelector('[data-rsvp-heading]');
    if (!id && heading) {
      const { translate } = await import('../scripts/i18n');
      heading.textContent = translate('rsvp_error_title', lang);
    }
    if (id) mountRsvpForm(root, id, lang);
  }
</script>
