---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md';
  type?: 'button' | 'submit' | 'reset';
  href?: string;
  disabled?: boolean;
  class?: string;
}
const { variant = 'secondary', size = 'md', type = 'button', href, disabled, class: className } = Astro.props;
const Tag = href ? 'a' : 'button';
---
<Tag
  class:list={["btn", `btn--${variant}`, `btn--${size}`, className]}
  type={href ? undefined : type}
  href={href}
  disabled={disabled}
>
  <slot />
</Tag>
