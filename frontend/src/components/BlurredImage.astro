---
import { Image } from 'astro:assets';
import { generateLqip } from '../scripts/lqip';

interface BlurredImageProps {
  src: ImageMetadata;
  lqipBuffer: Buffer;
  alt: string;
  widths: number[];
  sizes: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  lqipBuffer,
  alt,
  widths,
  sizes,
  class: className,
  loading = 'lazy',
  fetchpriority = 'auto',
} = Astro.props as BlurredImageProps;

const placeholder = await generateLqip(lqipBuffer);
---
<div class:list={["blurred-image", className]} data-blurred-image>
  <div
    class="blurred-image__placeholder"
    style={`background-image: url(data:image/webp;base64,${placeholder})`}
  />
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={loading}
    fetchpriority={fetchpriority}
    class="blurred-image__img"
  />
</div>

<style>
  .blurred-image { position: relative; }
  .blurred-image__placeholder {
    position: absolute;
    inset: 0;
    background-size: cover;
    filter: blur(20px);
    transform: scale(1.1);
    transition: opacity 0.3s ease;
    z-index: 0;
  }
  .blurred-image--loaded .blurred-image__placeholder {
    opacity: 0;
  }
  .blurred-image__img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .blurred-image__placeholder { transition: none; }
  }
</style>

<script>
  document.querySelectorAll('[data-blurred-image]').forEach((container) => {
    const img = container.querySelector<HTMLImageElement>('.blurred-image__img');
    if (img?.complete) {
      container.classList.add('blurred-image--loaded');
    } else {
      img?.addEventListener('load', () => container.classList.add('blurred-image--loaded'));
    }
  });
</script>
