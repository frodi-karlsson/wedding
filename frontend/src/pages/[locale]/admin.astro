---
import AdminPage from '../../components/AdminPage.astro';
import { langFromPath, NON_DEFAULT_LOCALES } from '../../scripts/i18n';

export function getStaticPaths() {
  // Exclude the default locale, which is served unprefixed at '/admin'.
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const lang = langFromPath(Astro.url.pathname);
---
<AdminPage lang={lang} />
