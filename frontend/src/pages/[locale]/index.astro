---
import RsvpPage from '../../components/RsvpPage.astro';
import { langFromPath, NON_DEFAULT_LOCALES } from '../../scripts/i18n';

export function getStaticPaths() {
  // Exclude the default 'en'. It is served unprefixed at '/', so emitting an
  // 'en' param would duplicate it at '/en/'.
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const lang = langFromPath(Astro.url.pathname);
---
<RsvpPage lang={lang} />
