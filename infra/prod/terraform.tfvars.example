# Copy to terraform.tfvars and fill in. NEVER commit terraform.tfvars.

do_token            = "dop_v1_xxxxxxxxxxxxxxxxxxxxxx"
ssh_public_key      = "ssh-ed25519 AAAA... your@email"

cloudflare_api_token  = "cfapi_xxxxxxxxxxxxxxxxxxxxxx"
cloudflare_account_id = "your-cloudflare-account-id"
cloudflare_zone_id    = "your-cloudflare-zone-id"

resend_api_key      = "re_xxxxxxxxxxxxxxxxxxxxxx"
admin_password      = "choose-a-strong-password"
session_secret      = "generate-a-random-secret"

ssh_allowed_ip      = "84.55.97.207/32"

r2_access_key_id     = "R2_ACCESS_KEY_ID"
r2_secret_access_key = "R2_SECRET_ACCESS_KEY"
r2_account_id        = "your-cloudflare-account-id"
healthchecks_ping_url = "https://hc-ping.com/your-uuid"

